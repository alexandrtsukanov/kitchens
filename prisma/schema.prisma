generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id         String     @unique @id @default(uuid())
    email      String     @unique
    password   String
    createdAt  DateTime   @default(now()) @map("created_at")
    updatedAt  DateTime   @default(now()) @map("updated_at")

    @@map("users")
}